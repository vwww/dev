{
  "name": "vwww",
  "version": "1.0.0",
  "description": "Victor's Website",
  "private": true,
  "scripts": {
    "start": "concurrently \"webpack --progress -w\" \"npm run serve\"",
    "serve": "cd docs && jekyll s",
    "build": "webpack --node-env production --progress && npm run build:jekyll",
    "build:dev": "webpack --progress && npm run build:jekyll || cd .",
    "build:jekyll": "cd docs && jekyll b",
    "clean": "rimraf docs/assets/dist docs/_data/manifest.json docs/_site",
    "eslint": "eslint scripts --ext .js,.jsx,.ts,.tsx || cd .",
    "eslint:fix": "npm run eslint --fix",
    "eslint:dump": "eslint --print-config ./.eslintrc.json",
    "format-fix": "npm run prettier && npm run eslint:fix",
    "prettier": "npm run prettier:typescript && npm run prettier:svelte",
    "prettier:svelte": "prettier --write 'src/**/*.svelte'",
    "prettier:typescript": "prettier --write 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theonlypwner/www_dev.git"
  },
  "author": "Victor",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/theonlypwner/www_dev/issues"
  },
  "homepage": "https://github.com/theonlypwner/www_dev#readme",
  "devDependencies": {
    "@types/bootstrap": "^4.6.0",
    "@types/jquery": "^3.5.5",
    "@types/jquery.timeago": "^1.0.29",
    "@types/jssha": "^2.0.0",
    "@types/leaflet": "^1.5.23",
    "@types/packery": "^1.4.31",
    "@types/plotly.js": "^1.54.9",
    "@typescript-eslint/eslint-plugin": "^4.16.1",
    "@typescript-eslint/parser": "^4.16.1",
    "concurrently": "^6.0.0",
    "css-loader": "^5.1.1",
    "eslint": "^7.21.0",
    "eslint-config-standard-with-typescript": "^20.0.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.3.1",
    "eslint-plugin-svelte3": "^3.1.2",
    "fast-glob": "^3.2.5",
    "mini-css-extract-plugin": "^1.3.9",
    "raw-loader": "^4.0.2",
    "rimraf": "^3.0.2",
    "sass": "^1.32.8",
    "sass-loader": "^11.0.1",
    "svelte-check": "^1.2.2",
    "svelte-loader": "^3.0.0",
    "svelte-preprocess": "^4.6.9",
    "ts-loader": "^8.0.17",
    "typescript": "^4.2.3",
    "webpack": "^5.24.3",
    "webpack-cli": "^4.5.0",
    "webpack-manifest-plugin": "^3.0.0",
    "webpack-remove-empty-scripts": "^0.7.1"
  },
  "dependencies": {
    "bootstrap": "^4.6.0",
    "bootswatch": "^4.6.0",
    "firebase": "^8.2.10",
    "highcharts": "^8.2.2",
    "jquery": "^3.6.0",
    "jssha": "^3.2.0",
    "leaflet": "^1.7.1",
    "packery": "^2.1.2",
    "popper.js": "1.16.1-lts || ^1.17.0",
    "svelte": "^3.35.0",
    "svg-pan-zoom": "^3.6.1"
  }
}
