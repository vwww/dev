{
  "name": "vwww",
  "version": "1.0.0",
  "description": "Victor's Website",
  "private": true,
  "scripts": {
    "start": "npm run build:dev:css && concurrently \"cross-env NODE_ENV=development rspack -w\" \"npm run serve\"",
    "serve": "cd docs && jekyll s",
    "build": "npm run build:prod:css && npm run build:prod:rspack && npm run build:jekyll",
    "build:dev": "npm run build:dev:css && npm run build:dev:rspack && npm run build:jekyll || cd .",
    "build:dev:css": "cross-env NODE_ENV=development node build_esbuild",
    "build:prod:css": "cross-env NODE_ENV=production node build_esbuild",
    "build:dev:rspack": "cross-env NODE_ENV=development rspack",
    "build:prod:rspack": "cross-env NODE_ENV=production rspack",
    "build:jekyll": "cd docs && jekyll b",
    "clean": "rimraf docs/assets/dist docs/_data/manifest.json docs/_site",
    "eslint": "eslint scripts || cd .",
    "eslint:fix": "npm run eslint --fix",
    "eslint:dump": "eslint --print-config ./.eslintrc.json",
    "format-fix": "npm run prettier && npm run eslint:fix",
    "prettier": "npm run prettier:typescript && npm run prettier:svelte",
    "prettier:svelte": "prettier --write 'src/**/*.svelte'",
    "prettier:typescript": "prettier --write 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theonlypwner/www_dev.git"
  },
  "author": "Victor",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/theonlypwner/www_dev/issues"
  },
  "homepage": "https://github.com/theonlypwner/www_dev#readme",
  "devDependencies": {
    "@rspack/cli": "^1.1.8",
    "@rspack/core": "^1.1.8",
    "@types/bootstrap": "^5.2.10",
    "@types/d3": "^7.4.3",
    "@types/jquery": "^3.5.32",
    "@types/leaflet": "^1.9.15",
    "@types/leaflet-fullscreen": "^1.0.9",
    "@types/packery": "^1.4.37",
    "@types/timeago": "^1.6.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.1.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.2",
    "esbuild-sass-plugin": "^3.3.1",
    "eslint": "^9.17.0",
    "eslint-config-love": "^114.0.0",
    "eslint-plugin-frontmatter": "^0.0.8",
    "eslint-plugin-html": "^8.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-svelte": "^2.46.1",
    "fast-glob": "^3.3.2",
    "rimraf": "^6.0.1",
    "rspack-manifest-plugin": "^5.0.3",
    "sass-embedded": "^1.83.0",
    "svelte-check": "^4.1.1",
    "svelte-loader": "^3.2.4",
    "svelte-preprocess": "^6.0.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "bootswatch": "^5.3.3",
    "d3": "^7.9.0",
    "firebase": "^11.1.0",
    "highcharts": "^12.1.2",
    "jquery": "^3.7.1",
    "jssha": "^3.3.1",
    "leaflet": "^1.9.4",
    "leaflet-fullscreen": "^1.0.2",
    "leaflet-hash": "^0.2.1",
    "leaflet-minimap": "^3.6.1",
    "packery": "^2.1.2",
    "svelte": "^5.16.0",
    "svg-pan-zoom": "^3.6.2",
    "timeago": "^1.6.7"
  }
}
