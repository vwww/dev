{
  "name": "vwww",
  "version": "1.0.0",
  "description": "Victor's Website",
  "private": true,
  "scripts": {
    "start": "concurrently \"webpack -w\" \"npm run serve\"",
    "serve": "cd docs && jekyll s",
    "build": "webpack --define-process-env-node-env production --progress && npm run build:jekyll",
    "build:dev": "webpack --progress && npm run build:jekyll || cd .",
    "build:jekyll": "cd docs && jekyll b",
    "clean": "rimraf docs/assets/dist docs/_data/manifest.json docs/_site",
    "eslint": "eslint scripts || cd .",
    "eslint:fix": "npm run eslint --fix",
    "eslint:dump": "eslint --print-config ./.eslintrc.json",
    "format-fix": "npm run prettier && npm run eslint:fix",
    "prettier": "npm run prettier:typescript && npm run prettier:svelte",
    "prettier:svelte": "prettier --write 'src/**/*.svelte'",
    "prettier:typescript": "prettier --write 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theonlypwner/www_dev.git"
  },
  "author": "Victor",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/theonlypwner/www_dev/issues"
  },
  "homepage": "https://github.com/theonlypwner/www_dev#readme",
  "devDependencies": {
    "@types/bootstrap": "^5.2.10",
    "@types/d3": "^7.4.3",
    "@types/jquery": "^3.5.32",
    "@types/leaflet": "^1.9.14",
    "@types/leaflet-fullscreen": "^1.0.9",
    "@types/packery": "^1.4.37",
    "@types/plotly.js": "^2.33.5",
    "@types/timeago": "^1.6.3",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "concurrently": "^9.1.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.14.0",
    "eslint-config-love": "^98.0.0",
    "eslint-plugin-frontmatter": "^0.0.8",
    "eslint-plugin-html": "^8.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-svelte": "^2.46.0",
    "fast-glob": "^3.3.2",
    "mini-css-extract-plugin": "^2.9.2",
    "raw-loader": "^4.0.2",
    "rimraf": "^6.0.1",
    "sass": "^1.80.6",
    "sass-loader": "^16.0.3",
    "svelte-check": "^4.0.6",
    "svelte-loader": "^3.2.4",
    "svelte-preprocess": "^6.0.3",
    "ts-loader": "^9.5.1",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "typescript": "^5.6.3",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4",
    "webpack-manifest-plugin": "^5.0.0",
    "webpack-remove-empty-scripts": "^1.0.4"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "bootswatch": "^5.3.3",
    "d3": "^7.9.0",
    "firebase": "^11.0.1",
    "highcharts": "^11.4.8",
    "jquery": "^3.7.1",
    "jssha": "^3.3.1",
    "leaflet": "^1.9.4",
    "leaflet-fullscreen": "^1.0.2",
    "leaflet-hash": "^0.2.1",
    "leaflet-minimap": "^3.6.1",
    "packery": "^2.1.2",
    "plotly.js": "^2.35.2",
    "svelte": "^4.2.19",
    "svg-pan-zoom": "^3.6.2",
    "timeago": "^1.6.7"
  }
}
