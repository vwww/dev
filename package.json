{
  "name": "vwww",
  "version": "1.0.0",
  "description": "Victor's Website",
  "private": true,
  "scripts": {
    "start": "concurrently \"webpack -w\" \"npm run serve\"",
    "serve": "cd docs && jekyll s",
    "build": "webpack --node-env production --progress && npm run build:jekyll",
    "build:dev": "webpack --progress && npm run build:jekyll || cd .",
    "build:jekyll": "cd docs && jekyll b",
    "clean": "rimraf docs/assets/dist docs/_data/manifest.json docs/_site",
    "eslint": "eslint scripts --ext .js,.jsx,.ts,.tsx || cd .",
    "eslint:fix": "npm run eslint --fix",
    "eslint:dump": "eslint --print-config ./.eslintrc.json",
    "format-fix": "npm run prettier && npm run eslint:fix",
    "prettier": "npm run prettier:typescript && npm run prettier:svelte",
    "prettier:svelte": "prettier --write 'src/**/*.svelte'",
    "prettier:typescript": "prettier --write 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theonlypwner/www_dev.git"
  },
  "author": "Victor",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/theonlypwner/www_dev/issues"
  },
  "homepage": "https://github.com/theonlypwner/www_dev#readme",
  "devDependencies": {
    "@types/bootstrap": "^5.1.6",
    "@types/d3": "^7.1.0",
    "@types/jquery": "^3.5.9",
    "@types/jquery.timeago": "^1.0.30",
    "@types/leaflet": "^1.7.6",
    "@types/packery": "^1.4.32",
    "@types/plotly.js": "^1.54.17",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "concurrently": "^6.4.0",
    "css-loader": "^5.2.7",
    "eslint": "^7.32.0",
    "eslint-config-standard-with-typescript": "^20.0.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.2.0",
    "eslint-plugin-svelte3": "^3.2.1",
    "fast-glob": "^3.2.7",
    "mini-css-extract-plugin": "^1.6.2",
    "raw-loader": "^4.0.2",
    "rimraf": "^3.0.2",
    "sass": "^1.44.0",
    "sass-loader": "^12.3.0",
    "svelte-check": "^2.2.10",
    "svelte-loader": "^3.1.2",
    "svelte-preprocess": "^4.9.8",
    "ts-loader": "^9.2.6",
    "typescript": "^4.5.2",
    "webpack": "^5.65.0",
    "webpack-cli": "^4.9.1",
    "webpack-manifest-plugin": "^3.2.0",
    "webpack-remove-empty-scripts": "^0.7.1"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.0",
    "bootstrap": "^5.1.3",
    "bootswatch": "^5.1.3",
    "d3": "^7.2.0",
    "firebase": "^8.10.0",
    "highcharts": "^9.3.2",
    "jquery": "^3.6.0",
    "jssha": "^3.2.0",
    "leaflet": "^1.7.1",
    "packery": "^2.1.2",
    "plotly.js": "^2.7.0",
    "svelte": "^3.44.2",
    "svg-pan-zoom": "^3.6.1",
    "timeago": "^1.6.7"
  }
}
