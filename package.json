{
  "name": "vwww",
  "version": "1.0.0",
  "description": "Victor's Website",
  "private": true,
  "scripts": {
    "start": "concurrently \"webpack -w\" \"npm run serve\"",
    "serve": "cd docs && jekyll s",
    "build": "webpack --define-process-env-node-env production --progress && npm run build:jekyll",
    "build:dev": "webpack --progress && npm run build:jekyll || cd .",
    "build:jekyll": "cd docs && jekyll b",
    "clean": "rimraf docs/assets/dist docs/_data/manifest.json docs/_site",
    "eslint": "eslint scripts || cd .",
    "eslint:fix": "npm run eslint --fix",
    "eslint:dump": "eslint --print-config ./.eslintrc.json",
    "format-fix": "npm run prettier && npm run eslint:fix",
    "prettier": "npm run prettier:typescript && npm run prettier:svelte",
    "prettier:svelte": "prettier --write 'src/**/*.svelte'",
    "prettier:typescript": "prettier --write 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theonlypwner/www_dev.git"
  },
  "author": "Victor",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/theonlypwner/www_dev/issues"
  },
  "homepage": "https://github.com/theonlypwner/www_dev#readme",
  "devDependencies": {
    "@types/bootstrap": "^5.2.6",
    "@types/d3": "^7.4.0",
    "@types/jquery": "^3.5.16",
    "@types/leaflet": "^1.9.0",
    "@types/packery": "^1.4.32",
    "@types/plotly.js": "^2.12.13",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "concurrently": "^7.6.0",
    "css-loader": "^6.7.3",
    "eslint": "^8.33.0",
    "eslint-config-standard-with-typescript": "^24.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-svelte3": "^4.0.0",
    "fast-glob": "^3.2.12",
    "mini-css-extract-plugin": "^2.7.2",
    "raw-loader": "^4.0.2",
    "rimraf": "^4.1.2",
    "sass": "^1.57.1",
    "sass-loader": "^13.2.0",
    "svelte-check": "^3.0.3",
    "svelte-loader": "^3.1.5",
    "svelte-preprocess": "^5.0.1",
    "ts-loader": "^9.4.2",
    "tsconfig-paths-webpack-plugin": "^4.0.0",
    "typescript": "^4.9.4",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "webpack-manifest-plugin": "^5.0.0",
    "webpack-remove-empty-scripts": "^1.0.1"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.6",
    "@types/leaflet-fullscreen": "^1.0.6",
    "@types/timeago": "^1.6.0",
    "bootstrap": "^5.2.3",
    "bootswatch": "^5.2.3",
    "d3": "^7.8.2",
    "firebase": "^9.16.0",
    "highcharts": "^10.3.3",
    "jquery": "^3.6.3",
    "jssha": "^3.3.0",
    "leaflet": "^1.9.3",
    "leaflet-fullscreen": "^1.0.2",
    "leaflet-hash": "^0.2.1",
    "leaflet-minimap": "^3.6.1",
    "packery": "^2.1.2",
    "plotly.js": "^2.18.0",
    "svelte": "^3.55.1",
    "svg-pan-zoom": "^3.6.1",
    "timeago": "^1.6.7"
  }
}
