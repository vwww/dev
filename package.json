{
  "name": "vwww",
  "version": "1.0.0",
  "description": "Victor's Website",
  "private": true,
  "scripts": {
    "start": "concurrently \"webpack -w\" \"npm run serve\"",
    "serve": "cd docs && jekyll s",
    "build": "webpack --node-env production --progress && npm run build:jekyll",
    "build:dev": "webpack --progress && npm run build:jekyll || cd .",
    "build:jekyll": "cd docs && jekyll b",
    "clean": "rimraf docs/assets/dist docs/_data/manifest.json docs/_site",
    "eslint": "eslint scripts --ext .js,.jsx,.ts,.tsx || cd .",
    "eslint:fix": "npm run eslint --fix",
    "eslint:dump": "eslint --print-config ./.eslintrc.json",
    "format-fix": "npm run prettier && npm run eslint:fix",
    "prettier": "npm run prettier:typescript && npm run prettier:svelte",
    "prettier:svelte": "prettier --write 'src/**/*.svelte'",
    "prettier:typescript": "prettier --write 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theonlypwner/www_dev.git"
  },
  "author": "Victor",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/theonlypwner/www_dev/issues"
  },
  "homepage": "https://github.com/theonlypwner/www_dev#readme",
  "devDependencies": {
    "@types/bootstrap": "^5.1.9",
    "@types/d3": "^7.1.0",
    "@types/jquery": "^3.5.14",
    "@types/jquery.timeago": "^1.0.30",
    "@types/leaflet": "^1.7.9",
    "@types/packery": "^1.4.32",
    "@types/plotly.js": "^1.54.20",
    "@typescript-eslint/eslint-plugin": "^5.12.1",
    "@typescript-eslint/parser": "^5.12.1",
    "concurrently": "^7.0.0",
    "css-loader": "^6.6.0",
    "eslint": "^8.10.0",
    "eslint-config-standard-with-typescript": "^21.0.1",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-svelte3": "^3.4.1",
    "fast-glob": "^3.2.11",
    "mini-css-extract-plugin": "^2.5.3",
    "raw-loader": "^4.0.2",
    "rimraf": "^3.0.2",
    "sass": "^1.49.9",
    "sass-loader": "^12.6.0",
    "svelte-check": "^2.4.5",
    "svelte-loader": "^3.1.2",
    "svelte-preprocess": "^4.10.4",
    "ts-loader": "^9.2.6",
    "typescript": "^4.5.5",
    "webpack": "^5.69.1",
    "webpack-cli": "^4.9.2",
    "webpack-manifest-plugin": "^4.1.1",
    "webpack-remove-empty-scripts": "^0.7.3"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.2",
    "bootstrap": "^5.1.3",
    "bootswatch": "^5.1.3",
    "d3": "^7.3.0",
    "firebase": "^9.6.7",
    "highcharts": "^9.3.3",
    "jquery": "^3.6.0",
    "jssha": "^3.2.0",
    "leaflet": "^1.7.1",
    "packery": "^2.1.2",
    "plotly.js": "^2.9.0",
    "svelte": "^3.46.4",
    "svg-pan-zoom": "^3.6.1",
    "timeago": "^1.6.7"
  }
}
