{
  "compilerOptions": {
    "baseUrl": "scripts",
    "paths": {
      "@/*": ["*"],
    },
    "outDir": "./tsc_temp",
    "strict": true,
    // "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "module": "ES6",
    "moduleResolution": "node",
    "target": "ES6",
    // "allowJs": true,
    // "importsNotUsedAsValues": "error",
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
  },
  "include": [
    "scripts",
    "typings.d.ts",
  ]
}